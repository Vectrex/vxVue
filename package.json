{
  "name": "vx-vue",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/vxvue.umd.js",
  "module": "./dist/vxvue.es.js",
  "exports": {
    ".": {
      "import": "./dist/vxvue.es.js",
      "require": "./dist/vxvue.umd.js"
    },
    "./vx-vue.css": "./dist/style.css",
    "./dist/*": "./dist/*"
  },
  "version": "1.4.6",
  "license": "MIT",
  "homepage": "https://vectrex.github.io/vxVue",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vectrex/vxVue.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "format": "prettier --write src/",
    "format:css": "rustywind --write src",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@heroicons/vue": "^2.2.0",
    "tailwindcss": "^4.2.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "vue": "^3.5.29",
    "@vueuse/core": "^14.2.1",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^28.1.0",
    "vite": "^7.3.1",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.9.0",
    "@vitest/eslint-plugin": "^1.6.9",
    "@vitejs/plugin-vue": "^6.0.4",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "prettier": "^3.8.1",
    "rustywind": "^0.24.3"
  }
}
